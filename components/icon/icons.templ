package icon 

import "strconv"
import "fmt"

templ (i *icon) component() {
	<uk-icon
		cls-custom={ i.clsCustom }
		icon={ i.name }
		stroke-width={ strconv.Itoa(i.strokeWidth) }
		height={ strconv.Itoa(i.height) }
		width={ strconv.Itoa(i.width) }
		forcePreventReRender={ fmt.Sprint(i.forcePreventReRender) }
		class={ i.GetClasses() }
		{ i.GetAttributes() ... }
	></uk-icon>
}
